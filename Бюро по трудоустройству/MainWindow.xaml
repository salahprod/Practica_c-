<Window x:Class="Бюро_по_трудоустройству.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Бюро по трудоустройству" Height="750" Width="1100" 
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Градиенты -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2C3E50" Offset="0"/>
            <GradientStop Color="#3498DB" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonGreen" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#27AE60" Offset="0"/>
            <GradientStop Color="#1E8449" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonBlue" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#3498DB" Offset="0"/>
            <GradientStop Color="#2980B9" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonOrange" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E67E22" Offset="0"/>
            <GradientStop Color="#D35400" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonRed" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E74C3C" Offset="0"/>
            <GradientStop Color="#C0392B" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonPurple" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#9B59B6" Offset="0"/>
            <GradientStop Color="#7D3C98" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonTeal" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1ABC9C" Offset="0"/>
            <GradientStop Color="#148F77" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonGray" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#95A5A6" Offset="0"/>
            <GradientStop Color="#7F8C8D" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonYellow" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F39C12" Offset="0"/>
            <GradientStop Color="#D68910" Offset="1"/>
        </LinearGradientBrush>

        <!-- Стили кнопок -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для DataGrid (запрещаем редактирование прямо в таблице) -->
        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E5E5"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3498DB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="#DCDFE6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="#DCDFE6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с градиентом -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" Padding="15" CornerRadius="10" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Бюро по трудоустройству" FontSize="22" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Управление работодателями, соискателями и сделками" FontSize="13" 
                           Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Панель кнопок -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,15">
            <Button x:Name="AddEmployerBtn" Content="🏢 Добавить работодателя" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonBlue}" 
                    Margin="3" Click="AddEmployerBtn_Click"/>

            <Button x:Name="AddSeekerBtn" Content="👤 Добавить соискателя" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonGreen}" 
                    Margin="3" Click="AddSeekerBtn_Click"/>

            <Button x:Name="AddDealBtn" Content="💰 Оформить сделку" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonOrange}" 
                    Margin="3" Click="AddDealBtn_Click"/>

            <!-- ОБЩАЯ КНОПКА ИЗМЕНИТЬ -->
            <Button x:Name="EditBtn" Content="✏️ Изменить" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonBlue}" 
                    Margin="3" Click="EditBtn_Click"/>

            <Button x:Name="DeleteSelectedBtn" Content="🗑️ Удалить выбранное" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonRed}" 
                    Margin="3" Click="DeleteSelectedBtn_Click"/>

            <Button x:Name="ReportBtn" Content="📊 Финансовый отчёт" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonPurple}" 
                    Margin="3" Click="ReportBtn_Click"/>

            <Button x:Name="ExportBtn" Content="📎 Экспорт в CSV" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonTeal}" 
                    Margin="3" Click="ExportBtn_Click"/>

            <Button x:Name="ClearAllBtn" Content="⚠️ Очистить всё" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonRed}" 
                    Margin="3" Click="ClearAllBtn_Click"/>

            <Button x:Name="RefreshBtn" Content="🔄 Обновить" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonGray}" 
                    Margin="3" Click="RefreshBtn_Click"/>

            <Button x:Name="TopEmployersBtn" Content="🏆 Топ работодателей" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonYellow}" 
                    Margin="3" Click="TopEmployersBtn_Click"/>

            <Button x:Name="StatsBtn" Content="📈 Статистика" 
                    Style="{StaticResource ModernButton}" Background="{StaticResource ButtonTeal}" 
                    Margin="3" Click="StatsBtn_Click"/>
        </WrapPanel>

        <!-- Основной контент с вкладками -->
        <TabControl x:Name="MainTabControl" Grid.Row="2">

            <!-- Вкладка: Работодатели -->
            <TabItem Header="🏢 Работодатели">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="5" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍 Поиск:" VerticalAlignment="Center" FontWeight="Bold" Margin="5" FontSize="13"/>
                            <TextBox x:Name="EmployerSearchBox" Grid.Column="1" Margin="5" Height="32" 
                                     TextChanged="EmployerSearchBox_TextChanged"/>
                            <Button x:Name="ClearEmployerSearchBtn" Grid.Column="2" Content="❌ Очистить" 
                                    Width="90" Height="32" Margin="5" Click="ClearEmployerSearchBtn_Click"
                                    Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="EmployersGrid" Grid.Row="1" AutoGenerateColumns="False" Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="Вид деятельности" Binding="{Binding ActivityType}" Width="200"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="250"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Соискатели -->
            <TabItem Header="👤 Соискатели">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="5" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍 Поиск:" VerticalAlignment="Center" FontWeight="Bold" Margin="5" FontSize="13"/>
                            <TextBox x:Name="SeekerSearchBox" Grid.Column="1" Margin="5" Height="32" 
                                     TextChanged="SeekerSearchBox_TextChanged"/>
                            <ComboBox x:Name="SeekerSearchFilter" Grid.Column="2" Width="130" Height="32" Margin="5"
                                      SelectionChanged="SeekerSearchFilter_SelectionChanged">
                                <ComboBoxItem Content="Все поля"/>
                                <ComboBoxItem Content="Фамилия"/>
                                <ComboBoxItem Content="Имя"/>
                                <ComboBoxItem Content="Квалификация"/>
                            </ComboBox>
                            <Button x:Name="ClearSeekerSearchBtn" Grid.Column="3" Content="❌ Очистить" 
                                    Width="90" Height="32" Margin="5" Click="ClearSeekerSearchBtn_Click"
                                    Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="JobSeekersGrid" Grid.Row="1" AutoGenerateColumns="False" Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="120"/>
                            <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="120"/>
                            <DataGridTextColumn Header="Квалификация" Binding="{Binding Qualification}" Width="150"/>
                            <DataGridTextColumn Header="Сфера" Binding="{Binding ActivityType}" Width="150"/>
                            <DataGridTextColumn Header="Ожидаемая ЗП" Binding="{Binding ExpectedSalary, StringFormat={}{0:N2} руб.}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Сделки -->
            <TabItem Header="💰 Сделки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="5" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍 Поиск:" VerticalAlignment="Center" FontWeight="Bold" Margin="5" FontSize="13"/>
                            <TextBox x:Name="DealSearchBox" Grid.Column="1" Margin="5" Height="32" 
                                     TextChanged="DealSearchBox_TextChanged"/>
                            <ComboBox x:Name="DealSearchFilter" Grid.Column="2" Width="130" Height="32" Margin="5"
                                      SelectionChanged="DealSearchFilter_SelectionChanged">
                                <ComboBoxItem Content="Все поля"/>
                                <ComboBoxItem Content="Соискатель"/>
                                <ComboBoxItem Content="Работодатель"/>
                            </ComboBox>
                            <Button x:Name="ClearDealSearchBtn" Grid.Column="3" Content="❌ Очистить" 
                                    Width="90" Height="32" Margin="5" Click="ClearDealSearchBtn_Click"
                                    Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="DealsGrid" Grid.Row="1" AutoGenerateColumns="False" Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Соискатель" Binding="{Binding JobSeeker.FullName}" Width="200"/>
                            <DataGridTextColumn Header="Работодатель" Binding="{Binding Employer.Name}" Width="200"/>
                            <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="180"/>
                            <DataGridTextColumn Header="Комиссионные" Binding="{Binding Commission, StringFormat={}{0:N2} руб.}" Width="150"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Статистика -->
            <TabItem Header="📈 Статистика">
                <ScrollViewer>
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#E8F8F5" Padding="20" CornerRadius="10" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="📊 Общая статистика" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>
                                <TextBlock x:Name="TotalEmployersText" FontSize="14" Margin="5" Foreground="#27AE60"/>
                                <TextBlock x:Name="TotalSeekersText" FontSize="14" Margin="5" Foreground="#3498DB"/>
                                <TextBlock x:Name="TotalDealsText" FontSize="14" Margin="5" Foreground="#E67E22"/>
                                <TextBlock x:Name="TotalIncomeText" FontSize="16" Margin="5" FontWeight="Bold" Foreground="#E74C3C"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Background="#FEF9E7" Padding="20" CornerRadius="10" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="🏆 Топ 5 работодателей по доходу" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>
                                <ItemsControl x:Name="TopEmployersList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FDEBD0" Padding="10" Margin="0,3" CornerRadius="5">
                                                <TextBlock Text="{Binding}" FontSize="13" Foreground="#7D6608"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Background="#EBF5FB" Padding="20" CornerRadius="10" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="🕐 Последние 5 сделок" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>
                                <ItemsControl x:Name="RecentDealsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#D6EAF8" Padding="10" Margin="0,3" CornerRadius="5">
                                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#1A5276"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>