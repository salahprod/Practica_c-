<Window x:Class="Бюро_по_трудоустройству.Dialogs.EmployerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Работодатель" Height="450" Width="550" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:*" VerticalAlignment="Center" FontWeight="Bold" Margin="5" Foreground="Red"/>
        <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Margin="5" Height="30" VerticalContentAlignment="Center"
                 ToolTip="Введите название организации"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Вид деятельности:*" VerticalAlignment="Center" FontWeight="Bold" Margin="5" Foreground="Red"/>
        <TextBox x:Name="ActivityTypeBox" Grid.Row="1" Grid.Column="1" Margin="5" Height="30" VerticalContentAlignment="Center"
                 ToolTip="Введите вид деятельности"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Адрес:*" VerticalAlignment="Center" FontWeight="Bold" Margin="5" Foreground="Red"/>
        <TextBox x:Name="AddressBox" Grid.Row="2" Grid.Column="1" Margin="5" Height="30" VerticalContentAlignment="Center"
                 ToolTip="Введите адрес"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Телефон:*" VerticalAlignment="Center" FontWeight="Bold" Margin="5" Foreground="Red"/>
        <TextBox x:Name="PhoneBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="30" VerticalContentAlignment="Center"
                 PreviewTextInput="PhoneBox_PreviewTextInput" ToolTip="Только цифры"/>

        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="* - обязательные поля" 
                   FontSize="10" Foreground="Gray" Margin="5,0,0,0"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,20,5,5">
            <Button x:Name="OkButton" Content="OK" Width="80" Height="30" Margin="5" Click="OkButton_Click" IsDefault="True" Background="#27AE60" Foreground="White"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="80" Height="30" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>