<Window x:Class="Бюро_по_трудоустройству.Dialogs.JobSeekerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Соискатель" Height="550" Width="600" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Фамилия:*" VerticalAlignment="Center" FontWeight="Bold" Margin="5" Foreground="Red"/>
        <TextBox x:Name="LastNameBox" Grid.Row="0" Grid.Column="1" Margin="5" Height="30" VerticalContentAlignment="Center"
                 ToolTip="Введите фамилию (только буквы)"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:*" VerticalAlignment="Center" FontWeight="Bold" Margin="5" Foreground="Red"/>
        <TextBox x:Name="FirstNameBox" Grid.Row="1" Grid.Column="1" Margin="5" Height="30" VerticalContentAlignment="Center"
                 ToolTip="Введите имя (только буквы)"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="PatronymicBox" Grid.Row="2" Grid.Column="1" Margin="5" Height="30" VerticalContentAlignment="Center"
                 ToolTip="Введите отчество (только буквы, необязательно)"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Квалификация:*" VerticalAlignment="Center" FontWeight="Bold" Margin="5" Foreground="Red"/>
        <TextBox x:Name="QualificationBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="30" VerticalContentAlignment="Center"
                 ToolTip="Введите квалификацию"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Желаемая сфера:*" VerticalAlignment="Center" FontWeight="Bold" Margin="5" Foreground="Red"/>
        <TextBox x:Name="ActivityTypeBox" Grid.Row="4" Grid.Column="1" Margin="5" Height="30" VerticalContentAlignment="Center"
                 ToolTip="Введите желаемую сферу деятельности"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ожидаемая ЗП:*" VerticalAlignment="Center" FontWeight="Bold" Margin="5" Foreground="Red"/>
        <Grid Grid.Row="5" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ExpectedSalaryBox" Grid.Column="0" Margin="5" Height="30" VerticalContentAlignment="Center"
                     PreviewTextInput="ExpectedSalaryBox_PreviewTextInput" ToolTip="Только цифры"/>
            <TextBlock Grid.Column="1" Text="руб." VerticalAlignment="Center" Margin="5,0,5,0"/>
        </Grid>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Иные данные:" VerticalAlignment="Top" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="OtherInfoBox" Grid.Row="6" Grid.Column="1" Margin="5" Height="80" 
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 ToolTip="Дополнительная информация (необязательно)"/>

        <TextBlock Grid.Row="7" Grid.ColumnSpan="2" Text="* - обязательные поля" 
                   FontSize="10" Foreground="Gray" Margin="5,10,0,0"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,10,5,5">
            <Button x:Name="OkButton" Content="OK" Width="80" Height="30" Margin="5" Click="OkButton_Click" IsDefault="True" Background="#27AE60" Foreground="White"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="80" Height="30" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>