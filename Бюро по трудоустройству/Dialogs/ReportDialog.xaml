<Window x:Class="Бюро_по_трудоустройству.Dialogs.ReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Финансовый отчёт" Height="550" Width="700" 
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Финансовый отчёт бюро по трудоустройству" 
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" 
                   Margin="0,0,0,20" Foreground="#2C3E50"/>

        <Border Grid.Row="1" Background="#F8F9FA" Padding="15" CornerRadius="8" 
                BorderBrush="#E9ECEF" BorderThickness="1" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Всего сделок:" 
                          FontWeight="Bold" FontSize="14" Margin="5"/>
                <TextBlock x:Name="TotalDealsText" Grid.Row="0" Grid.Column="1" 
                          FontSize="14" Margin="5" Foreground="#2C3E50"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Общий доход:" 
                          FontWeight="Bold" FontSize="14" Margin="5"/>
                <TextBlock x:Name="TotalIncomeText" Grid.Row="1" Grid.Column="1" 
                          FontSize="14" Margin="5" Foreground="#27AE60" FontWeight="Bold"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Средний доход за сделку:" 
                          FontWeight="Bold" FontSize="14" Margin="5"/>
                <TextBlock x:Name="AverageIncomeText" Grid.Row="2" Grid.Column="1" 
                          FontSize="14" Margin="5" Foreground="#2980B9"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Средняя зарплата соискателей:" 
                          FontWeight="Bold" FontSize="14" Margin="5"/>
                <TextBlock x:Name="AverageSalaryText" Grid.Row="3" Grid.Column="1" 
                          FontSize="14" Margin="5" Foreground="#E67E22"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2" Text="Доход по работодателям:" 
                   FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

        <DataGrid x:Name="EmployerIncomeGrid" Grid.Row="3" AutoGenerateColumns="False" 
                  Margin="0,5,0,0" IsReadOnly="True" 
                  AlternatingRowBackground="#F8F9FA" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Работодатель" Binding="{Binding EmployerName}" Width="*"/>
                <DataGridTextColumn Header="Количество сделок" Binding="{Binding DealCount}" Width="120"/>
                <DataGridTextColumn Header="Доход" Binding="{Binding TotalIncome, StringFormat={}{0:N2} руб.}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>